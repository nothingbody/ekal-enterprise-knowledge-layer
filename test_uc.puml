@startuml
left to right direction
skinparam defaultFontName 宋体
skinparam usecase {
    BackgroundColor White|#E0E0E0
    BorderColor black
}
skinparam actor {
    BackgroundColor white
    BorderColor black
}
skinparam rectangle {
    BorderColor black
}

actor "普通用户" as U1

rectangle "知枢企业智能知识平台" {
    usecase "登录认证" as UC1
    usecase "知识库管理" as UC2
    usecase "文档入库" as UC3
    usecase "智能对话" as UC4
    usecase "模型配置" as UC5
    usecase "个人中心" as UC6
}

U1 -- UC1
U1 -- UC2
U1 -- UC3
U1 -- UC4
U1 -- UC5
U1 -- UC6
@enduml
