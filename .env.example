# 知枢 RAG 平台环境变量示例
# 复制此文件为 .env 并修改配置

# ============ 数据库 ============
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ============ Backend ============
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
BACKEND_SECRET_KEY=REPLACE_WITH_RANDOM_BACKEND_SECRET
BACKEND_CORS_ORIGINS=http://localhost:3000
VECTOR_STORE_TYPE=chroma
LOG_LEVEL=INFO

# ============ Server ============
SERVER_SECRET_KEY=REPLACE_WITH_RANDOM_SERVER_SECRET
SERVER_CORS_ORIGINS=http://localhost:3001
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_INITIAL_ADMIN_PASSWORD

# ============ 云连接（可选）============
# Backend 连接 Server 的地址（Docker 内部网络）
CENTRAL_SERVER_URL=http://server:8001
