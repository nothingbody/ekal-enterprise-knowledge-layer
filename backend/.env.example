# ═══════════════════════════════════════════
# RAG Platform — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Application ──
DEBUG=false
APP_NAME=RAG知识库平台
# DESKTOP_MODE=true  # Set by desktop_main.py automatically; enables SPA serving + SQLite defaults

# ── Security ──
# IMPORTANT: Generate a strong random key for production!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ──
# SQLite (default, local desktop mode)
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
# PostgreSQL (optional, only when you need an external database)
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/rag_platform

# ── Redis ──
# 桌面端默认不需要 Redis；仅在需要独立消息代理时再启用
REDIS_URL=redis://localhost:6379/0

# ── Vector Store ──
VECTOR_STORE_TYPE=chroma
CHROMA_MODE=embedded
# CHROMA_HOST=localhost
# CHROMA_PORT=8100
CHROMA_DATA_DIR=./data/chroma

# ── File Upload ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# ── CORS ──
# 逗号分隔的允许源。生产环境必须设置具体域名，禁止使用 *。
# 示例: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60

# ── Chunking Defaults ──
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_TOP_K=5

# ── Logging ──
LOG_LEVEL=INFO

# ── Sandbox (代码执行) ──
# 桌面版启用后自动使用本地 subprocess，无需 Docker；技能脚本可调用外部 API
# SANDBOX_ENABLED=true
# SANDBOX_USE_LOCAL=true   # 桌面版默认；服务器版用 Docker 时设为 false
# SANDBOX_NETWORK_DISABLED=false  # 允许网络访问（技能脚本调用外部 API）

# ── Platform Built-in Model (平台内置模型，供用户免费试用) ──
# 配置后所有用户自动拥有一个平台提供的模型，无需用户自行输入 API Key
# PLATFORM_LLM_API_BASE=https://api.deepseek.com/v1
# PLATFORM_LLM_API_KEY=YOUR_PLATFORM_API_KEY
# PLATFORM_LLM_MODEL_NAME=deepseek-chat
# PLATFORM_LLM_DISPLAY_NAME=知枢官方模型 (DeepSeek)
# PLATFORM_EMBEDDING_API_BASE=https://api.openai.com/v1
# PLATFORM_EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY
# PLATFORM_EMBEDDING_MODEL_NAME=text-embedding-3-small
# PLATFORM_EMBEDDING_DISPLAY_NAME=知枢官方 Embedding

# ── Central Server (云连接，可选) ──
# 配置后桌面端将连接中心服务器进行统一认证、技能市场和用量上报
# CENTRAL_SERVER_URL=https://your-domain.com
# 经统一 Nginx 对外部署时，/api/v1 会指向节点后端，中心服必须用此前缀（与 deploy/nginx.conf 一致）
# CENTRAL_API_PREFIX=/api/central/v1
# CLOUD_HEARTBEAT_INTERVAL=300
# CLOUD_USAGE_REPORT_INTERVAL=3600

# ── DJI Cloud API (可选) ──
# 真实 App Key / License 必须放在本地 .env 或部署平台 Secret 中，不要提交到仓库。
# DJI_CLOUD_API_APP_NAME=REPLACE_WITH_DJI_APP_NAME
# DJI_CLOUD_API_APP_ID=REPLACE_WITH_DJI_APP_ID
# DJI_CLOUD_API_APP_KEY=REPLACE_WITH_DJI_APP_KEY
# DJI_CLOUD_API_LICENSE=REPLACE_WITH_DJI_LICENSE
