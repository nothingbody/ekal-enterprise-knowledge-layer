{
  "name": "@rag-platform/shared-utils",
  "version": "0.1.0",
  "description": "知枢 RAG 平台前端共享工具库",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./jwt": {
      "import": "./dist/jwt.js",
      "types": "./dist/jwt.d.ts"
    },
    "./request": {
      "import": "./dist/request.js",
      "types": "./dist/request.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "axios": "^1.0.0"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "typescript": "^5.7.3"
  }
}
