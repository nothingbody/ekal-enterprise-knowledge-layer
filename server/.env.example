# ═══════════════════════════════════════════════════
# 知枢中心服务器 — 环境变量配置
# 复制此文件为 .env 并修改对应值
# ═══════════════════════════════════════════════════

# ── 运行模式 ──
DEBUG=false

# ── 数据库 ──
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://rag:${POSTGRES_PASSWORD}@postgres:5432/rag_central

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── 安全 ──
# 生产环境务必修改，建议使用: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY

# ── CORS 跨域 ──
# 多个源用逗号分隔。本地开发 admin-frontend 时需包含 http://localhost:5173
CORS_ORIGINS=http://localhost,http://localhost:5173

# ── 管理员初始账号 ──
# 仅首次启动且无用户时自动创建
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_INITIAL_ADMIN_PASSWORD

# ── 注册策略 ──
ALLOW_REGISTRATION=true
INVITE_CODE=

# ── 部署 ──
ADMIN_PORT=80
# Uvicorn worker 数量，建议 CPU 核数 × 2 + 1
WEB_WORKERS=2
