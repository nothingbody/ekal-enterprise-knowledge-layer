# ═══════════════════════════════════════════════════
# 知枢 RAG 平台 — 统一生产部署环境变量
# 复制为 .env 并修改所有 change-me 值
# ═══════════════════════════════════════════════════

# ── 数据库 ──
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ── 安全密钥 ──
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
SERVER_SECRET_KEY=REPLACE_WITH_RANDOM_SERVER_SECRET
BACKEND_SECRET_KEY=REPLACE_WITH_RANDOM_BACKEND_SECRET

# ── Redis ──
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── 公网访问 ──
SERVER_PUBLIC_IP=
PUBLIC_ORIGIN=http://localhost

# ── 跨域 ──
CORS_ORIGINS=http://localhost

# ── 管理员初始账号 (首次启动自动创建) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_INITIAL_ADMIN_PASSWORD

# ── 注册策略 ──
ALLOW_REGISTRATION=true
INVITE_CODE=

# ── 调试模式 ──
DEBUG=false
